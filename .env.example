# -----------------------------------------------------------------------
# Agent Subscription API — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to source control.
# -----------------------------------------------------------------------

# Mainlayer API key — obtain from https://mainlayer.xyz/dashboard
MAINLAYER_API_KEY=your_mainlayer_api_key_here

# The Mainlayer resource ID that represents this agent.
# Created when you register your agent at https://mainlayer.xyz/dashboard
RESOURCE_ID=res_your_resource_id_here

# Public base URL for this service (used in 402 response URLs).
# In production set this to your deployed URL, e.g. https://my-agent.example.com
PUBLIC_BASE_URL=http://localhost:8000

# Server config
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
